#!/bin/bash
#SBATCH -N 1
#SBATCH -c 1
#SBATCH -t 00:05:00
# GENERATED by nb2slurm for the 'monte_carlo_pi' workflow.
# The varying values arrive as environment variables (see --export in submit).

set -e
export NB2SLURM=1   # lets notebooks detect batch execution via nb2slurm.on_hpc()
# Enable `conda activate` in this non-interactive shell. `conda shell.bash hook`
# defines the conda shell function directly, so we don't rely on ~/.bashrc (which
# usually returns early for non-interactive shells and leaves conda unusable).
eval "$(conda shell.bash hook)"
conda activate montecarlo

python scripts/run_workflow.py $N_SAMPLES $SEED