#!/bin/bash
# GENERATED by nb2slurm for the '{{ name }}' workflow.
#
# Cancels the jobs listed in jobs.txt by their job name (one subject per line).
set -euo pipefail

JOBS_FILE="${1:-scripts/jobs.txt}"

while read -r {{ read_vars }} _rest; do
    [ -z "{{ first_var_ref }}" ] && continue
    case "{{ first_var_ref }}" in \#*) continue ;; esac
    key="{{ key_expr }}"
    scancel --name="$key" && echo "cancelled $key"
done < "$JOBS_FILE"
