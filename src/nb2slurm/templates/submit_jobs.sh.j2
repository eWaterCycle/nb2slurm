#!/bin/bash
# GENERATED by nb2slurm for the '{{ name }}' workflow.
#
# The THROTTLED submitter: like submit_batch.sh, but caps how many jobs run at
# once to {{ concurrency }} (using SLURM 'afterany' dependencies). Use this for big
# runs where you don't want to flood the queue. For the simple all-at-once
# version, see submit_batch.sh.
#
# Reads scripts/jobs.txt (generated from jobs.json); each line holds: {{ read_vars }}
set -euo pipefail

JOBS_FILE="${1:-scripts/jobs.txt}"
CONCURRENCY={{ concurrency }}
jobids=()

while read -r {{ read_vars }} _rest; do
    [ -z "{{ first_var_ref }}" ] && continue        # skip blank lines
    case "{{ first_var_ref }}" in \#*) continue ;; esac  # skip comments

    key="{{ key_expr }}"
    outdir="{{ outdir_expr }}"
    mkdir -p "$outdir"

    dep_args=()
    if (( ${#jobids[@]} >= CONCURRENCY )); then
        dep_args=(--dependency=afterany:"${jobids[-CONCURRENCY]}")
    fi

    jobid=$(sbatch --parsable "${dep_args[@]}" \
        --job-name="$key" \
        --output="$outdir/$key.out" \
        --error="$outdir/$key.err" \
        --export=ALL,{{ export_expr }} \
        scripts/job.slurm)

    jobids+=("$jobid")
    echo "submitted $key -> $jobid"
done < "$JOBS_FILE"
