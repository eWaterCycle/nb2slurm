#!/bin/bash
#SBATCH -N {{ resources.nodes | default(1) }}
#SBATCH -c {{ resources.cpus | default(1) }}
#SBATCH -t {{ resources.time | default("01:00:00") }}
{% if resources.partition %}#SBATCH -p {{ resources.partition }}
{% endif %}
{% if resources.memory %}#SBATCH --mem={{ resources.memory }}
{% endif %}
# GENERATED by nb2slurm for the '{{ name }}' workflow.
# The varying values arrive as environment variables (see --export in submit).

set -e
{% for line in setup %}
{{ line }}
{% endfor %}
{% if conda_env %}
conda init
source ~/.bashrc
conda activate {{ conda_env }}
{% endif %}
{% for m in mounts %}
mkdir -p {{ m.mountpoint }}
rclone mount --read-only --allow-non-empty {{ m.remote }} {{ m.mountpoint }} &
{% endfor %}

python scripts/{{ runner_name }}{% for v in varying_env %} ${{ v }}{% endfor %}
