#!/usr/bin/env python
"""Papermill driver for the '{{ name }}' workflow.

GENERATED by nb2slurm — do not edit by hand; re-run Workflow.build() instead.

Invoked on the cluster as:
    python scripts/{{ runner_name }}{% for v in varying %} <{{ v }}>{% endfor %}

It (1) skips the subject if already recorded done, (2) runs the first notebook
to produce settings.json, (3) runs the remaining notebooks against that settings
file, and (4) records the subject as done.
"""
import sys
from pathlib import Path

import papermill as pm

from nb2slurm import Done

VARYING = {{ varying }}
NOTEBOOKS = {{ notebooks }}
KERNEL = "{{ kernel }}"

# --- parse the varying values from argv ---------------------------------------
if len(sys.argv) - 1 != len(VARYING):
    sys.exit(f"expected {len(VARYING)} args {VARYING}, got {sys.argv[1:]}")
values = dict(zip(VARYING, sys.argv[1:]))
key = "_".join(values.values())

outdir = Path("{{ output_dir }}", *values.values())
outdir.mkdir(parents=True, exist_ok=True)
done = Done("{{ done_csv }}")

# --- skip if this subject already finished ------------------------------------
if done.is_done(key):
    print(f"{key} already done: terminating")
    sys.exit()

# --- notebook 0 creates settings.json -----------------------------------------
first = NOTEBOOKS[0]
pm.execute_notebook(
    first,
    str(outdir / f"{Path(first).stem}_executed.ipynb"),
    parameters={**values, "outdir": str(outdir)},
    kernel_name=KERNEL,
)

settings_path = outdir / "settings.json"
if not settings_path.exists():
    sys.exit(f"first notebook did not produce {settings_path}")

# --- run the remaining notebooks against settings.json ------------------------
for nb in NOTEBOOKS[1:]:
    name = Path(nb).stem
    print(f"running {name}")
    pm.execute_notebook(
        nb,
        str(outdir / f"{name}_executed.ipynb"),
        parameters={"settings_path": str(settings_path)},
        kernel_name=KERNEL,
    )

done.mark(key)
print(f"{key} complete")
